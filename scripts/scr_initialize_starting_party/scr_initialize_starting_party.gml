///============================================================================
/// scr_initialize_starting_party
/// Creates the default party for a new game.
///============================================================================

function scr_initialize_starting_party()
{
    //---------------------------------------------------------------------
    // Create Party Array
    //---------------------------------------------------------------------

    global.party = array_create(4, noone);

    //---------------------------------------------------------------------
    // Cooper
    //---------------------------------------------------------------------

    var _cooper = new Character("Cooper");

    global.party[0] = _cooper;

    //---------------------------------------------------------------------
    // Starting Equipment
    //---------------------------------------------------------------------

    scr_give_item_to_character(_cooper, "shock_baton", "backpack");

    //---------------------------------------------------------------------
    // Auto-Equip Starter Gear
    //---------------------------------------------------------------------

    scr_equip_item(_cooper, 0);

    //---------------------------------------------------------------------
    // Bake Equipment Bonuses
    //---------------------------------------------------------------------

    scr_update_character_stats(_cooper);
}